&CONTROL
    calculation   = "vc-relax",
    etot_conv_thr =   1.0000000000d-04,
    forc_conv_thr =   1.0000000000d-03,
    pseudo_dir    = '/home/asif/pseudo/',
    outdir = './output',
    tprnfor = .true.,
    tstress = .true.,
    verbosity = 'high',
/

&SYSTEM
   ibrav = 0,
   degauss = 0.002,
   nat = 10,
   ntyp = 4,
   ecutwfc = 85,
   ecutrho = 700,
   nosym = .false.,
   occupations = 'smearing',
   smearing = 'gaussian',
/

&ELECTRONS
  conv_thr =   1.0000000000d-7,
  electron_maxstep = 500,
  mixing_beta =   3.0000000000d-01,
  diagonalization = 'david',      ! for faster ittration alternative we use 'cg'
/

&IONS
    ion_dynamics = "bfgs",
/

&CELL
    cell_dynamics = 'bfgs',
    cell_dofree   = 'all',
    press_conv_thr = 0.5,
/
